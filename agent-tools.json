{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FX SDK Agent Tools",
  "description": "JSON Schema for registering SDK methods as tools. Amounts are decimal strings; convert to bigint before calling the SDK.",
  "definitions": {
    "market": {
      "type": "string",
      "enum": ["ETH", "BTC"],
      "description": "ETH or BTC"
    },
    "positionType": {
      "type": "string",
      "enum": ["long", "short"],
      "description": "long or short"
    },
    "userAddress": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$",
      "description": "Ethereum address"
    },
    "tokenAddress": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$",
      "description": "Token address; prefer tokens.*"
    },
    "amountWei": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "Wei as decimal string; convert to bigint before SDK call"
    },
    "slippagePercent": {
      "type": "number",
      "exclusiveMinimum": 0,
      "exclusiveMaximum": 100,
      "description": "Slippage in percent (e.g. 1 = 1%)"
    },
    "sourceChainId": {
      "type": "integer",
      "enum": [1, 8453],
      "description": "Source chain: 1 = Ethereum, 8453 = Base"
    },
    "destChainId": {
      "type": "integer",
      "enum": [1, 8453],
      "description": "Destination chain: 1 = Ethereum, 8453 = Base"
    },
    "bridgeToken": {
      "type": "string",
      "description": "Token key (e.g. fxUSD, fxSAVE) or OFT address on source chain"
    },
    "fxsaveTokenIn": {
      "type": "string",
      "enum": ["usdc", "fxUSD", "fxUSDBasePool"],
      "description": "fxSAVE deposit/withdraw token key"
    },
    "gaugeAddress": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$",
      "description": "Gauge contract address; get from getGaugeList"
    },
    "unlockTimestamp": {
      "type": "integer",
      "description": "Unix timestamp in seconds; auto-aligned to WEEK (604800s). Max 4 years from now."
    },
    "boostIndex": {
      "type": "integer",
      "minimum": 0,
      "description": "Token index of the boost delegation to cancel"
    }
  },
  "tools": [
    {
      "name": "getPositions",
      "description": "List positions for user in market and type (long/short). Use to get positionId before other ops.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "market": { "$ref": "#/definitions/market" },
          "type": { "$ref": "#/definitions/positionType" }
        },
        "required": ["userAddress", "market", "type"]
      }
    },
    {
      "name": "increasePosition",
      "description": "Open new (positionId 0) or add to existing. Returns routes with txs to execute in order.",
      "parameters": {
        "type": "object",
        "properties": {
          "market": { "$ref": "#/definitions/market" },
          "type": { "$ref": "#/definitions/positionType" },
          "positionId": { "type": "integer", "minimum": 0, "description": "0 = new, >0 = existing" },
          "leverage": { "type": "number", "exclusiveMinimum": 0, "description": "Leverage multiplier" },
          "inputTokenAddress": { "$ref": "#/definitions/tokenAddress" },
          "amountWei": { "$ref": "#/definitions/amountWei" },
          "slippage": { "$ref": "#/definitions/slippagePercent" },
          "userAddress": { "$ref": "#/definitions/userAddress" }
        },
        "required": ["market", "type", "positionId", "leverage", "inputTokenAddress", "amountWei", "slippage", "userAddress"]
      }
    },
    {
      "name": "reducePosition",
      "description": "Reduce size or fully close. isClosePosition: true to close.",
      "parameters": {
        "type": "object",
        "properties": {
          "market": { "$ref": "#/definitions/market" },
          "type": { "$ref": "#/definitions/positionType" },
          "positionId": { "type": "integer", "minimum": 1, "description": "Existing position ID" },
          "outputTokenAddress": { "$ref": "#/definitions/tokenAddress" },
          "amountWei": { "$ref": "#/definitions/amountWei" },
          "slippage": { "$ref": "#/definitions/slippagePercent" },
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "isClosePosition": { "type": "boolean", "description": "True to close fully", "default": false }
        },
        "required": ["market", "type", "positionId", "outputTokenAddress", "amountWei", "slippage", "userAddress"]
      }
    },
    {
      "name": "adjustPositionLeverage",
      "description": "Adjust leverage of an existing position.",
      "parameters": {
        "type": "object",
        "properties": {
          "market": { "$ref": "#/definitions/market" },
          "type": { "$ref": "#/definitions/positionType" },
          "positionId": { "type": "integer", "minimum": 1 },
          "leverage": { "type": "number", "exclusiveMinimum": 0 },
          "slippage": { "$ref": "#/definitions/slippagePercent" },
          "userAddress": { "$ref": "#/definitions/userAddress" }
        },
        "required": ["market", "type", "positionId", "leverage", "slippage", "userAddress"]
      }
    },
    {
      "name": "depositAndMint",
      "description": "Deposit collateral and mint fxUSD. Long only.",
      "parameters": {
        "type": "object",
        "properties": {
          "market": { "$ref": "#/definitions/market" },
          "positionId": { "type": "integer", "minimum": 0 },
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "depositTokenAddress": { "$ref": "#/definitions/tokenAddress" },
          "depositAmountWei": { "$ref": "#/definitions/amountWei" },
          "mintAmountWei": { "$ref": "#/definitions/amountWei" }
        },
        "required": ["market", "positionId", "userAddress", "depositTokenAddress", "depositAmountWei", "mintAmountWei"]
      }
    },
    {
      "name": "repayAndWithdraw",
      "description": "Repay fxUSD and withdraw collateral. Long only.",
      "parameters": {
        "type": "object",
        "properties": {
          "market": { "$ref": "#/definitions/market" },
          "positionId": { "type": "integer", "minimum": 1 },
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "repayAmountWei": { "$ref": "#/definitions/amountWei" },
          "withdrawAmountWei": { "$ref": "#/definitions/amountWei" },
          "withdrawTokenAddress": { "$ref": "#/definitions/tokenAddress" }
        },
        "required": ["market", "positionId", "userAddress", "repayAmountWei", "withdrawAmountWei", "withdrawTokenAddress"]
      }
    },
    {
      "name": "getBridgeQuote",
      "description": "Get LayerZero V2 bridge fee quote for Base <-> Ethereum OFT. Returns nativeFee and lzTokenFee in wei.",
      "parameters": {
        "type": "object",
        "properties": {
          "sourceChainId": { "$ref": "#/definitions/sourceChainId" },
          "destChainId": { "$ref": "#/definitions/destChainId" },
          "token": { "$ref": "#/definitions/bridgeToken" },
          "amountWei": { "$ref": "#/definitions/amountWei" },
          "recipient": { "$ref": "#/definitions/userAddress" },
          "sourceRpcUrl": { "type": "string", "description": "Optional RPC URL for source chain" }
        },
        "required": ["sourceChainId", "destChainId", "token", "amountWei", "recipient"]
      }
    },
    {
      "name": "buildBridgeTx",
      "description": "Build bridge tx payload (to, data, value) for Base <-> Ethereum via LayerZero V2 OFT. Send on source chain.",
      "parameters": {
        "type": "object",
        "properties": {
          "sourceChainId": { "$ref": "#/definitions/sourceChainId" },
          "destChainId": { "$ref": "#/definitions/destChainId" },
          "token": { "$ref": "#/definitions/bridgeToken" },
          "amountWei": { "$ref": "#/definitions/amountWei" },
          "recipient": { "$ref": "#/definitions/userAddress" },
          "refundAddress": { "$ref": "#/definitions/userAddress" },
          "sourceRpcUrl": { "type": "string", "description": "Optional RPC URL for source chain" }
        },
        "required": ["sourceChainId", "destChainId", "token", "amountWei", "recipient"]
      }
    },
    {
      "name": "getFxSaveBalance",
      "description": "Get user fxSAVE balance (shares wei and optional assets wei). Read-only.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" }
        },
        "required": ["userAddress"]
      }
    },
    {
      "name": "getFxSaveRedeemStatus",
      "description": "Get cooldown status: pending redeem amount, redeemableAt, isCooldownComplete. Use before getRedeemTx.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" }
        },
        "required": ["userAddress"]
      }
    },
    {
      "name": "getFxSaveClaimable",
      "description": "Redeem status plus preview receive (amountYieldOutWei, amountStableOutWei from previewRedeem — fxUSD + USDC to receive on claim). Use to show Min Receive before claim.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" }
        },
        "required": ["userAddress"]
      }
    },
    {
      "name": "getRedeemTx",
      "description": "Build claim tx(s) after cooldown. Call when getFxSaveRedeemStatus returns isCooldownComplete true. Returns txs to execute in order.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "receiver": { "$ref": "#/definitions/userAddress", "description": "Receiver of claimed assets; defaults to userAddress" }
        },
        "required": ["userAddress"]
      }
    },
    {
      "name": "depositFxSave",
      "description": "Deposit into fxSAVE. tokenIn: usdc, fxUSD, or fxUSDBasePool. Returns txs (approve + deposit); execute in order. Convert amountWei to bigint.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "tokenIn": { "$ref": "#/definitions/fxsaveTokenIn" },
          "amountWei": { "$ref": "#/definitions/amountWei" },
          "slippage": { "$ref": "#/definitions/slippagePercent", "description": "Optional; used for usdc/fxUSD deposit" }
        },
        "required": ["userAddress", "tokenIn", "amountWei"]
      }
    },
    {
      "name": "withdrawFxSave",
      "description": "Withdraw from fxSAVE. tokenOut fxUSDBasePool → direct redeem; usdc/fxUSD with instant false → requestRedeem (cooldown); usdc/fxUSD with instant true → instant redeem (slippage required). Returns txs; execute in order. Convert amountWei to bigint.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "tokenOut": { "$ref": "#/definitions/fxsaveTokenIn" },
          "amountWei": { "$ref": "#/definitions/amountWei" },
          "instant": { "type": "boolean", "description": "True for instant withdraw (usdc/fxUSD only); false for requestRedeem or redeem", "default": false },
          "slippage": { "$ref": "#/definitions/slippagePercent", "description": "Required when instant is true" }
        },
        "required": ["userAddress", "tokenOut", "amountWei"]
      }
    },
    {
      "name": "getLockInfo",
      "description": "Read veFXN lock status: lockedAmount, lockEnd, vePower, lockStatus, pendingWstETH rewards, delegation info. Read-only.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" }
        },
        "required": ["userAddress"]
      }
    },
    {
      "name": "createLock",
      "description": "Lock FXN to get veFXN. Returns approve + create_lock txs. unlockTime auto-aligned to WEEK boundary, max 4 years.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "amountWei": { "$ref": "#/definitions/amountWei" },
          "unlockTime": { "$ref": "#/definitions/unlockTimestamp" }
        },
        "required": ["userAddress", "amountWei", "unlockTime"]
      }
    },
    {
      "name": "increaseLockAmount",
      "description": "Add more FXN to existing lock. Returns approve + increase_amount txs. Requires active lock.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "amountWei": { "$ref": "#/definitions/amountWei" }
        },
        "required": ["userAddress", "amountWei"]
      }
    },
    {
      "name": "extendLockTime",
      "description": "Extend lock end time. New unlockTime must be greater than current lockEnd.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "unlockTime": { "$ref": "#/definitions/unlockTimestamp" }
        },
        "required": ["userAddress", "unlockTime"]
      }
    },
    {
      "name": "withdrawLock",
      "description": "Withdraw FXN after lock expires. Only callable when lockStatus is 'expired'.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" }
        },
        "required": ["userAddress"]
      }
    },
    {
      "name": "claimLockRewards",
      "description": "Claim pending wstETH rewards from FeeDistributor.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" }
        },
        "required": ["userAddress"]
      }
    },
    {
      "name": "delegateBoost",
      "description": "Delegate veFXN boost to another address via VotingEscrowBoost.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "receiver": { "$ref": "#/definitions/userAddress", "description": "Address to receive the boost delegation" },
          "amountWei": { "$ref": "#/definitions/amountWei" },
          "endTime": { "$ref": "#/definitions/unlockTimestamp", "description": "Delegation end timestamp" }
        },
        "required": ["userAddress", "receiver", "amountWei", "endTime"]
      }
    },
    {
      "name": "undelegateBoost",
      "description": "Undelegate veFXN boost by token index. initialAmount is the original delegated amount (uint128).",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "boostIndex": { "$ref": "#/definitions/boostIndex" },
          "initialAmountWei": { "$ref": "#/definitions/amountWei", "description": "Original delegated amount (uint128)" }
        },
        "required": ["userAddress", "boostIndex", "initialAmountWei"]
      }
    },
    {
      "name": "getGaugeList",
      "description": "List all Liquidity Gauges (name, gauge address, LP token) from Aladdin API. No params required. Read-only.",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "getEarnPosition",
      "description": "Read user's gauge position: stakedBalance, pendingFxn, pendingRewards. Read-only.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "gaugeAddress": { "$ref": "#/definitions/gaugeAddress" }
        },
        "required": ["userAddress", "gaugeAddress"]
      }
    },
    {
      "name": "earnDeposit",
      "description": "Deposit LP tokens into gauge. Returns approve + deposit txs; execute in order.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "gaugeAddress": { "$ref": "#/definitions/gaugeAddress" },
          "lpTokenAddress": { "$ref": "#/definitions/tokenAddress", "description": "LP token address paired with the gauge" },
          "amountWei": { "$ref": "#/definitions/amountWei" }
        },
        "required": ["userAddress", "gaugeAddress", "lpTokenAddress", "amountWei"]
      }
    },
    {
      "name": "earnWithdraw",
      "description": "Withdraw LP tokens from gauge.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "gaugeAddress": { "$ref": "#/definitions/gaugeAddress" },
          "amountWei": { "$ref": "#/definitions/amountWei" }
        },
        "required": ["userAddress", "gaugeAddress", "amountWei"]
      }
    },
    {
      "name": "claimFxn",
      "description": "Claim FXN rewards via TokenMinter.mint(gauge).",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "gaugeAddress": { "$ref": "#/definitions/gaugeAddress" }
        },
        "required": ["userAddress", "gaugeAddress"]
      }
    },
    {
      "name": "claimRewards",
      "description": "Claim extra (non-FXN) rewards from gauge. receiver defaults to userAddress.",
      "parameters": {
        "type": "object",
        "properties": {
          "userAddress": { "$ref": "#/definitions/userAddress" },
          "gaugeAddress": { "$ref": "#/definitions/gaugeAddress" },
          "receiver": { "$ref": "#/definitions/userAddress", "description": "Receiver of rewards; defaults to userAddress" }
        },
        "required": ["userAddress", "gaugeAddress"]
      }
    }
  ]
}
