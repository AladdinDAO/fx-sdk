# Private Key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# RPC URL (optional, defaults to mainnet)
RPC_URL=https://ethereum-rpc.publicnode.com

# Chain ID (optional, defaults to 1 for mainnet)
CHAIN_ID=1

# User Address (optional, for get-positions.ts / get-fxsave-balance.ts, will be derived from PRIVATE_KEY if not set)
USER_ADDRESS=

POSITION_ID=

# fxSAVE deposit (fxsave-deposit.ts): tokenIn = usdc | fxUSD | fxUSDBasePool
FXSAVE_TOKEN_IN=usdc
# fxSAVE deposit amount in wei (optional; defaults to 10 USDC or 10 fxUSD depending on tokenIn)
# FXSAVE_AMOUNT_WEI=

# fxSAVE withdraw (fxsave-withdraw.ts): instant = true | false
FXSAVE_INSTANT=false
# fxSAVE withdraw tokenOut = usdc | fxUSD | fxUSDBasePool
FXSAVE_TOKEN_OUT=fxUSDBasePool
# fxSAVE shares to redeem in wei (optional; defaults to 1e18)
# FXSAVE_SHARES_WEI=

# ── Earn (Gauge LP Mining) ──────────────────────────────────────────────────
# Gauge contract address (required for earn-* scripts; get from earn-gauge-list.ts)
GAUGE_ADDRESS=

# LP token address (optional; if omitted, resolved automatically from gauge)
# LP_TOKEN_ADDRESS=

# Amount of LP to deposit, decimal string e.g. "10.5" (optional; defaults to all wallet balance)
# DEPOSIT_AMOUNT_LP=

# Amount of LP to withdraw, decimal string e.g. "5" (optional; defaults to 50% of staked)
# WITHDRAW_AMOUNT_LP=

# Receiver address for claimRewards (optional; defaults to userAddress)
# RECEIVER_ADDRESS=

# ── Lock (veFXN) ────────────────────────────────────────────────────────────
# Amount of FXN to lock, decimal string e.g. "100" (optional; lock-create default 100, lock-increase default 10)
# LOCK_AMOUNT_FXN=

# Lock duration in days (optional; lock-create default 365)
# LOCK_DAYS=
